# Force LF line endings for all files that run in Linux containers
* text=auto
*.sh text eol=lf
entrypoint.sh text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.prisma text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.conf text eol=lf

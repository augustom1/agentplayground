# ── Dependencies ──
node_modules
npm-debug.log*

# ── Build artifacts ──
.next
out

# ── Git ──
.git
.gitignore

# ── IDE / OS ──
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Env secrets ──
.env
.env.local
.env.*.local

# ── Docs ──
# Exclude root-level .md files (dev docs, not needed at runtime)
*.md
!README.md
# Re-include docs/ directory — needed by index-docs endpoint at runtime
!docs/
!docs/**
# Re-include business/ — indexed into the Brain at runtime
!business/
!business/**
# Re-include root context files read by index-docs
!CLAUDE.md
!HANDOFF.md

# ── Docker ──
Dockerfile
docker-compose.yml
docker-compose*.yml

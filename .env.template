# ─────────────────────────────────────────────────────────────────────────────
# Agent Playground — Environment Variables Template
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────────────────
# Your root domain. All subdomains are auto-created via wildcard DNS.
# DNS: A record @ → VPS IP, A record * → VPS IP
DOMAIN=yourdomain.com

# Email for Let's Encrypt SSL certificates (Traefik auto-renews)
ACME_EMAIL=you@yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Shared by the dashboard, n8n, and pgvector.
# setup.sh auto-generates this. Change only if you need a specific value.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=agent_dashboard

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for caching and future queue support.
REDIS_PASSWORD=changeme_redis_password

# ── Agent Dashboard ───────────────────────────────────────────────────────────
# AUTH_SECRET: JWT signing secret. Must be ≥32 chars random hex.
# Generate: openssl rand -hex 32
AUTH_SECRET=changeme_auth_secret_min_32_chars

# Public URL of the app (used by NextAuth for callbacks)
NEXTAUTH_URL=https://app.yourdomain.com
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com

# Cron job authorization. Must match the CRON_SECRET in docker-compose.
# Generate: openssl rand -hex 32
CRON_SECRET=changeme_cron_secret

# ── AI Providers ──────────────────────────────────────────────────────────────
# Anthropic Claude API (optional — Ollama works without it)
# Get from: console.anthropic.com → API Keys
# Without this, only Ollama (local) models are available.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (optional — only needed for Whisper transcription in Telegram/chat)
# Get from: platform.openai.com → API Keys
# Without this, voice note transcription is disabled.
# OPENAI_API_KEY=sk-...

# ── Ollama (Local LLMs) ───────────────────────────────────────────────────────
# Path on HOST where Ollama stores model files.
# Use a dedicated volume/disk to keep models off the root disk.
# Hetzner example: mount a 100GB block volume at /mnt/ollama-data
OLLAMA_DATA_PATH=/var/lib/ollama

# Space-separated list of models to auto-pull on container start.
# No-op if model already exists. First download takes 5–20 min.
# RAM guide (no GPU): 3b ~2GB | 7b ~5GB | 14b ~9GB
OLLAMA_AUTO_PULL=qwen2.5:3b qwen2.5:7b

# ── n8n ───────────────────────────────────────────────────────────────────────
# n8n workflow automation. Access at https://n8n.yourdomain.com
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=changeme_n8n_encryption_key
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme_n8n_password
N8N_HOST=n8n.yourdomain.com
N8N_PROTOCOL=https

# ── 2nd Brain (Obsidian Vault) ────────────────────────────────────────────────
# Path inside Docker containers where the vault is mounted.
# Matches the volume mount in docker-compose.yml — don't change unless you move the volume.
VAULT_PATH=/var/syncthing/vault

# Internal URL of the obsidian-mcp container (used for read/write via MCP protocol)
OBSIDIAN_MCP_URL=http://obsidian-mcp:3001

# Secret for n8n → /api/brain/index calls (protects the indexing endpoint)
# Generate: openssl rand -hex 32
# Set in n8n as an environment variable: BRAIN_SECRET
BRAIN_SECRET=changeme_brain_secret

# Set to true once your vault is set up to inject context into Keeper chat
VAULT_CONTEXT_ENABLED=false

# Syncthing API key (fill in AFTER first run — copy from Syncthing UI → Actions → Settings → API Key)
# SYNCTHING_API_KEY=

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
# Create a bot at @BotFather. All Telegram messages auto-save to vault.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=   # openssl rand -hex 20

# Register webhook after deploy:
# curl "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#   -d "url=https://app.yourdomain.com/api/telegram/webhook?secret_token=<SECRET>"

# ── Payments (optional) ───────────────────────────────────────────────────────
# Stripe (credit card payments)
# Get from: dashboard.stripe.com → Developers → API Keys
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# MercadoPago (payments for Latin America — ar.yourdomain.com)
# Get from: mercadopago.com.ar/developers → Credentials
# MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

# ── Auto-Install Tools via SSH (optional) ────────────────────────────────────
# SSH key for installing npm/pip/MCP packages on the VPS via the chat interface
# Generate: ssh-keygen -t ed25519 -f ~/.ssh/vps_key
# VPS_SSH_HOST=95.217.163.247
# VPS_SSH_USER=root
# VPS_SSH_KEY=   # base64 < ~/.ssh/vps_key

# ── Email Channel (optional) ─────────────────────────────────────────────────
# Outbound email via Resend (used for notifications)
# Get from: resend.com → API Keys
# RESEND_API_KEY=re_...

# ── Channels (optional) ──────────────────────────────────────────────────────
# WhatsApp via Twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=

# ── Self-Registration ────────────────────────────────────────────────────────
# Set to false for open registration, true to require invite code
REQUIRE_INVITE_CODE=true

# ── Mode ─────────────────────────────────────────────────────────────────────
# vps = full stack on server, laptop = local dev with reduced services
PLAYGROUND_MODE=vps
